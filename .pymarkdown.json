{
  "extensions": {
    "front-matter": {
      "enabled": true
    }
  },
  "plugins": {
    "md003": {
      "style": "atx"
    },
    "md004": {
      "style": "dash"
    },
    "md007": {
      "enabled": false
    },
    "md013": {
      "enabled": false
    },
    "md024": {
      "siblings_only": true
    },
    "md026": {
      "punctuation": ".,;:!。，、；：！？"
    },
    "md029": {
      "style": "one_or_ordered"
    },
    "md033": {
      "enabled": false
    },
    "md035": {
      "style": "---"
    },
    "md041": {
      "enabled": false
    },
    "md046": {
      "style": "fenced"
    },
    "md048": {
      "style": "backtick"
    }
  }
}
